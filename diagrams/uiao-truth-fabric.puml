@startuml UIAO_Truth_Fabric
' Appendix B — Truth Fabric Cross-Dependency Diagram

skinparam backgroundColor #FEFEFE
skinparam componentBackgroundColor #E8F8E8
skinparam componentBorderColor #2E7D32
skinparam componentFontSize 12
skinparam arrowColor #2C3E50

title **Appendix B — Truth Fabric**\n//Internal & Cross-Plane Dependencies//

component "B-01\nCanonical Claim\nSchema" as B01 {
  portin "ADR-005" as a005
}

component "B-02\nIdentity\nAnchoring" as B02 {
  portin "ADR-008" as a008
}

component "B-03\nMulti-Cloud\nIdentity Matrix" as B03 {
  portin "ADR-007" as a007
}

component "B-04\nControl Mapping\nGovernance" as B04 {
  portin "ADR-010" as a010
  portin "ADR-011" as a011
}

' Internal dependencies [NEW (Proposed)]
B01 --> B04 : claims feed\ncontrol mapping
B02 --> B03 : identity anchoring\ndrives multi-cloud matrix
B03 --> B04 : identity matrix\ninforms control scope

' Cross-plane outbound [NEW (Proposed)]
component "A-01 Adapter\nLifecycle" as A01 #E8F0FE
component "C-01 Drift\nDetection" as C01 #FFF3E0
component "D-01 Evidence\nDeterminism" as D01 #FCE4EC
component "D-04 Evidence\nCorrelation" as D04 #FCE4EC
component "E-02 Mission-Partner\nCorridors" as E02 #EDE7F6
component "E-03 Cross-Fabric\nConsistency" as E03 #EDE7F6

B01 ..> D01 : claims -> evidence\ndeterminism
B01 ..> E03 : consistency gate
B02 ..> E02 : identity -> corridors
B03 ..> A01 : multi-cloud -> adapters
B04 ..> C01 : baselines -> drift
B04 ..> D04 : mapping -> correlation

note bottom
  Truth Fabric is the canonical source of claims,
  identity, and control baselines.
  GCC-Moderate = M365 SaaS only. Not Azure.
end note

@enduml
