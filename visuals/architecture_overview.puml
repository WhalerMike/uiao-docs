@startuml architecture_overview
title UIAO Architecture Overview
skinparam backgroundColor #1a1a2e
skinparam componentStyle rectangle

package "Identity Plane" {
  [EntraID / ICAM] as ICAM
  [MFA / Conditional Access] as CA
}
package "Addressing Plane" {
  [IPAM / DNS] as IPAM
  [Network Policy Engine] as NPE
}
package "Overlay Plane" {
  [Policy Orchestrator] as PO
  [Telemetry Collector] as TC
}
package "Application Layer" {
  [GCC High Workloads] as GCC
  [ServiceNow / Connect] as SN
}

ICAM --> PO : identity assertions
IPAM --> PO : address bindings
PO --> CA : enforce policy
PO --> TC : emit telemetry
CA --> GCC : allow/deny
CA --> SN : allow/deny
@enduml
