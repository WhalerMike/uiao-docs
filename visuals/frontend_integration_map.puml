@startuml frontend_integration_map
title Frontend Integration Map
skinparam componentStyle rectangle

package "User-Facing Layer" {
  [M365 Portal] as M365
  [Teams Client] as TEAMS
  [ServiceNow Portal] as SNP
}
package "Identity Broker" {
  [EntraID SSO] as SSO
}
package "Backend Services" {
  [Amazon Connect CTI] as CTI
  [SharePoint GCC] as SP
  [Power Platform] as PP
}

M365 --> SSO
TEAMS --> SSO
SNP --> SSO
SSO --> CTI : SAML assertion
SSO --> SP : OAuth token
SSO --> PP : delegated access
@enduml
