@startuml data_flow
title UIAO Data Flow
skinparam sequenceMessageAlign center

actor "User" as U
participant "EntraID" as EID
participant "Conditional\nAccess" as CA
participant "Policy\nOrchestrator" as PO
participant "Application" as APP
database "Audit Log" as LOG

U -> EID : Login request
EID -> CA : Evaluate identity
CA -> PO : Request policy decision
PO --> CA : Allow + conditions
CA --> EID : Token with claims
EID --> U : Access token
U -> APP : Request + token
APP -> LOG : Write audit event
APP --> U : Response
@enduml
