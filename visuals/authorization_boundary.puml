@startuml authorization_boundary
title UIAO Authorization Boundary
skinparam rectangleBorderColor #0078d4

rectangle "FedRAMP Authorization Boundary" {
  rectangle "Identity Services" {
    component "EntraID" as EID
    component "ADFS" as ADFS
  }
  rectangle "Compute / Workloads" {
    component "GCC High Tenant" as GCC
    component "Azure Gov VMs" as AVM
  }
  rectangle "Management Plane" {
    component "Intune MDM" as MDM
    component "Defender XDR" as DEF
  }
}
rectangle "External" {
  actor "Federal User" as FU
  actor "Contractor" as CON
}

FU --> EID : authenticate
CON --> EID : authenticate
EID --> GCC : token
MDM --> AVM : policy push
DEF --> GCC : threat signals
@enduml
