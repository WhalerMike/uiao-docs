@startuml uiao_planes
title UIAO Three-Plane Model
skinparam packageStyle rectangle

package "Identity Plane\n(WHO)" #dbeafe {
  component "EntraID / ICAM" as ICAM
  component "MFA / PIV" as PIV
  component "Identity Governance" as IGA
}
package "Addressing Plane\n(WHERE)" #dcfce7 {
  component "IPAM / DDI" as IPAM
  component "DNS Resolver" as DNS
  component "Network Segmentation" as SEG
}
package "Overlay Plane\n(HOW)" #fef9c3 {
  component "Policy Orchestrator" as PO
  component "Telemetry Engine" as TE
  component "Zero Trust Broker" as ZTB
}

ICAM --> PO : identity context
IPAM --> PO : address context
PO --> ZTB : unified policy decision
ZTB --> TE : emit enforcement event
@enduml
