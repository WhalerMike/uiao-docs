@startuml user_to_app_zt_journey
title User to App — Zero Trust Journey
actor "Federal User" as U
participant "PIV/MFA\nAuth" as MFA
participant "EntraID\nCA" as CA
participant "UIAO Policy\nOrchestrator" as PO
participant "Zero Trust\nBroker" as ZTB
participant "GCC High\nApplication" as APP

U -> MFA : Present PIV credential
MFA --> CA : Identity confirmed
CA -> PO : Request access decision
PO -> PO : Evaluate ABAC + location
PO --> CA : Decision: Permit
CA -> ZTB : Issue scoped token
ZTB --> U : Session established
U -> APP : Access request + token
APP --> U : Authorized response
@enduml
