@startuml incident_escalation_tree
title Incident Escalation Tree
skinparam activityDiamondBackgroundColor #fff3cd

start
:Detect Anomaly\n(Defender XDR / SIEM);
:Auto-triage Severity;
if (Critical?) then (yes)
  :Page SOC Lead;
  :Invoke IR Playbook;
  :Notify CISO;
else (no)
  if (High?) then (yes)
    :Create ServiceNow P2 Ticket;
    :Notify Team Lead;
  else (no)
    :Create ServiceNow P3 Ticket;
    :Assign to On-call Analyst;
  endif
endif
:Collect Evidence + Timeline;
:Remediate;
:Post-Incident Review;
stop
@enduml
