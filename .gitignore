# ============================================
# UIAO Canonical .gitignore
# Prevents drift, export contamination, and noise
# ============================================

# --- Generated Documents (never commit) ---
*.docx
*.pptx
*.pdf
*.html
*.csv

# --- Quarto Outputs ---
/_site/
/docs/*.html
*.qmd

# --- Export Directories ---
exports/
exports/**

# --- Rendered Diagrams ---
*.png.rendered
*.svg.rendered

# --- Temporary / Local Files ---
~$*
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db

# --- Python / Build Artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# --- Node / JS (if ever used) ---
node_modules/

# --- VSCode / IDE ---
.vscode/
.idea/

# --- Logs ---
*.log

